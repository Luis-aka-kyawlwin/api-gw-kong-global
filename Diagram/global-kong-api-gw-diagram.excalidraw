      "isDeleted": false,
      "boundElements": [],
      "updated": 1777313008704,
      "link": null,
      "locked": false,
      "text": "2  global-kong-api-gateway listener (HTTP :80) evaluates hostname\n3  Matching global HTTPRoute selects domain proxy backendRef\n4  ReferenceGrant allows cross-namespace backend reference\n5  Traffic forwarded to domain kong-*-gateway-proxy service\n6  Domain gateway + local HTTPRoute routes to first app service\n7  East-west service-to-service calls continue within namespace\n",
      "fontSize": 14.211615924231019,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2  global-kong-api-gateway listener (HTTP :80) evaluates hostname\n3  Matching global HTTPRoute selects domain proxy backendRef\n4  ReferenceGrant allows cross-namespace backend reference\n5  Traffic forwarded to domain kong-*-gateway-proxy service\n6  Domain gateway + local HTTPRoute routes to first app service\n7  East-west service-to-service calls continue within namespace\n",
      "lineHeight": 1.25,
      "baseline": 11,
      "autoResize": true
    },
